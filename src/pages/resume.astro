---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../site-config";

const resumeFile = "/resume.pdf";
---

<script>
  import { animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";

  animate([loaderAnimation] as AnimationSequence);
</script>

<Layout
  title={`${SITE.author.fullName} - Resume`}
  description="Resume and experience overview."
>
  <main class="w-full min-h-screen px-4 py-8 md:px-8 md:py-12 text-white max-w-5xl mx-auto">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-primary-100 hover:text-primary-100 bg-darkslate-900 hover:bg-darkslate-800 hover:border-primary-500 w-fit px-4 py-2 border border-darkslate-400 rounded-lg transition-all duration-200"
      >Back</a
    >

    <div class="mt-10 mb-6 flex flex-wrap items-center justify-between gap-3">
      <h1 class="text-4xl md:text-5xl font-bold text-neutral-50">Resume</h1>
      <a
        href={resumeFile}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-primary-100 bg-darkslate-900 hover:bg-darkslate-800 hover:border-primary-500 px-5 py-2.5 border border-darkslate-400 rounded-lg transition-all duration-200"
      >
        Download PDF
      </a>
    </div>

    <div class="rounded-lg border border-darkslate-400 bg-darkslate-500 overflow-hidden h-[75vh]">
      <iframe
        src={resumeFile}
        title="Resume PDF"
        class="w-full h-full"
      ></iframe>
    </div>

    <p class="text-neutral-400 text-sm mt-4">
      If your resume does not appear, place your file at public/resume.pdf.
    </p>
  </main>
</Layout>

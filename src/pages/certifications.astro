---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../site-config";

const certifications = [
  {
    title: "Deep Learning Specialization",
    issuer: "Coursera",
    year: "2024",
    credentialUrl: "#",
  },
  {
    title: "Machine Learning with Python",
    issuer: "freeCodeCamp",
    year: "2023",
    credentialUrl: "#",
  },
  {
    title: "LangGraph and Agentic AI",
    issuer: "Self-directed",
    year: "2025",
    credentialUrl: "#",
  },
];
---

<script>
  import { animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";

  animate([loaderAnimation] as AnimationSequence);
</script>

<Layout
  title={`${SITE.author.fullName} - Certifications`}
  description="Professional certifications and learning milestones in AI, ML, and software engineering."
>
  <main class="w-full min-h-screen px-4 py-8 md:px-8 md:py-12 text-white max-w-4xl mx-auto">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-neutral-300 hover:text-neutral-100 bg-neutral-900 hover:bg-neutral-800 hover:border-neutral-500 w-fit px-4 py-2 border border-neutral-600 rounded-lg transition-all duration-200"
      >Back</a
    >

    <div class="mt-10 mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-neutral-50 mb-3">
        Certifications
      </h1>
      <p class="text-neutral-300 text-lg leading-relaxed max-w-3xl">
        A curated list of my certifications and focused learning tracks.
      </p>
    </div>

    <section class="grid gap-4">
      {
        certifications.map((cert) => (
          <article class="rounded-lg border border-darkslate-400 hover:border-neutral-500 bg-darkslate-500 p-6 transition-all duration-300">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-xl font-semibold text-neutral-100">{cert.title}</h2>
                <p class="text-neutral-300 mt-1">{cert.issuer}</p>
              </div>
              <span class="text-sm text-neutral-400">{cert.year}</span>
            </div>
            <a
              href={cert.credentialUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 mt-4 text-neutral-200 hover:text-neutral-50"
            >
              View credential
            </a>
          </article>
        ))
      }
    </section>
  </main>
</Layout>

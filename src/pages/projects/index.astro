---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card/index.astro";
import { SITE } from "../../site-config";

const projects = [
  {
    title: "AI Research Assistant",
    description: "Built an Agentic AI multi-agent research pipeline using LangGraph, Groq (Llama 3.3 70B), and Tavily - deployed on Hugging Face Spaces with Docker",
    slug: "/ai-research-assistant",
  },
  {
    title: "Document Q&A (RAG)",
    description:
      "Upload a PDF and ask questions about it. Uses sentence-transformers, FAISS, and a Hugging Face-hosted LLM.",
    slug: "/document-qna-rag",
  },
  {
    title: "Climate and Wealth Analysis",
    description:
      "A data analysis pipeline that explores how temperature and latitude relate to GDP per capita across 160+ countries.",
    slug: "/climate-wealth-analysis",
  },
  {
    title: "EEG Motor Action Classifier",
    description:
      "A real-time BCI pipeline for classifying grab vs throw motor actions from EEG signals using CSP + LDA and LSL streaming.",
    slug: "/eeg-grab-throw-motor-bci",
  },
  {
    title: "Braitenberg Vehicle Simulation",
    description:
      "A Braitenberg vehicle simulation in Unreal Engine 5 with customizable sensor, motor, and morphology settings.",
    slug: "/braitenberg-vehicle-unreal-engine",
  },
  {
    title: "Flood Prediction in Pakistan",
    description:
      "A machine learning project that predicts floods in Pakistan using Google Earth Engine data and compares several regression models.",
    slug: "/final-year-project-flood-prediction-pakistan-ml",
  },
];
---

<script>
  import { animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../../lib/constants";

  animate([loaderAnimation] as AnimationSequence);
</script>

<Layout
  title={`${SITE.author.fullName} - Projects`}
  description="A collection of experiments and creative explorations with different technologies."
>
  <main
    class="w-screen h-screen flex flex-col justify-start items-start max-w-3xl mx-auto p-8 text-white"
  >
    <a
      href="/"
      class="text-primary-100 bg-darkslate-900 hover:bg-darkslate-800 hover:border-primary-500 px-4 py-2 mb-8 border-1 border-solid border-darkslate-400 rounded-lg transition-all duration-200"
      >Back</a
    >
    <h1 class="text-4xl font-bold mb-4 text-neutral-100">Projects</h1>
    <div class="grid grid-cols-2 gap-4 w-full">
      {
        projects.map((project) => (
          <Card
            href={`/projects${project.slug}`}
            height="h-auto"
            colSpan="md:col-span-1"
          >
            <div class="text-darkslate-50">
              <h2 class="font-semibold text-2xl">{project.title}</h2>
              <p class="text-darkslate-300">{project.description}</p>
            </div>
          </Card>
        ))
      }
    </div>
  </main>
</Layout>
